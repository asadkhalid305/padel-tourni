# Supabase server-side access. Never expose the service-role key to browser code.
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3100
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_SECRET_KEY=your_secret_key
ADMIN_ROLE_API_SECRET=change_me_for_admin_role_endpoints
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Local Supabase Google OAuth. Required before running `supabase start` if you
# want local Google sign-in through the Supabase auth service.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your_google_web_oauth_client_id
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=your_google_web_oauth_client_secret

# Optional: higher Context7 MCP rate limits. The committed MCP config works without it.
CONTEXT7_API_KEY=
